# Environment Variables
NODE_ENV=development
PORT=3001

# Microservices ports
GATEWAY_PORT=3100
AGENTS_PORT=3002
WS_PORT=3003
ENGINEERING_INTELLIGENCE_PORT=3201
ENGINEERING_INTELLIGENCE_FRONTEND_URL=http://localhost:3000

# Internal service routing
AGENTS_SERVICE_URL=http://localhost:3002
LEGACY_SERVICE_URL=http://localhost:3001
ENGINEERING_INTELLIGENCE_SERVICE_URL=http://localhost:3201
INTERNAL_CONTEXT_SECRET=replace_with_strong_internal_secret

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Database
MONGODB_URI=mongodb://localhost:27017/ai-agent-team

# AI Model API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_claude_key_here
GOOGLE_AI_API_KEY=your_gemini_key_here
MOONSHOT_API_KEY=your_kimi_key_here

# OpenAI Stability (optional)
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=1

# Optional: Proxy for AI model requests (if direct network is blocked)
AI_PROXY_URL=http://127.0.0.1:7890

# OpenCode SDK
OPENCODE_SERVER_URL=http://localhost:4096

# Engineering Intelligence
GITHUB_TOKEN=your_github_token_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Encryption
# 用于加密存储API Key的主密钥
# 请生成一个强密钥，例如: openssl rand -base64 32
# 重要：一旦设置并创建加密数据后，请勿更改此密钥，否则已加密数据将无法解密
ENCRYPTION_KEY=your_encryption_key_here_min_16_chars

# ============================================
# Tool APIs - 工具真实 API 配置 (Composio)
# ============================================

# Composio API Key - 统一的工具平台
# 注册地址: https://www.composio.dev
# Composio 提供 1000+ 工具的统一接入（包括 Slack、Gmail、Search 等）
# 免费额度: 1000 次/月，无需单独管理各平台 OAuth
COMPOSIO_API_KEY=ak_yWMRCXiXFTgQWDe3xeal

# Web Search 配置 (Serper via Composio)
# Composio 会自动处理 Serper 的认证，无需单独配置 SERPER_API_KEY
# 如需使用自己的 Serper API Key（可选）
SERPER_API_KEY=

# Slack 配置 (via Composio)
# 在 Composio Dashboard 中连接 Slack 账号后，通过 Composio 调用
# 如需使用自己的 Slack Bot Token（可选）
SLACK_BOT_TOKEN=

# Gmail 配置 (via Composio)
# 在 Composio Dashboard 中连接 Gmail 账号后，通过 Composio 调用
# 如需使用自己的 Gmail OAuth（可选）
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
