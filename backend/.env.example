# Environment Variables
NODE_ENV=development
PORT=3001

# Workspace
AGENT_WORKSPACE_ROOT=/path/to/your/project/root

# Microservices ports
GATEWAY_PORT=3100
AGENTS_PORT=3002
WS_PORT=3003
ENGINEERING_INTELLIGENCE_PORT=3201
ENGINEERING_INTELLIGENCE_FRONTEND_URL=http://localhost:3000

# Internal service routing
AGENTS_SERVICE_URL=http://localhost:3002
LEGACY_SERVICE_URL=http://localhost:3001
ENGINEERING_INTELLIGENCE_SERVICE_URL=http://localhost:3201
INTERNAL_CONTEXT_SECRET=replace_with_strong_internal_secret

# Tools auth mode: legacy | hybrid | jwt-strict
TOOLS_AUTH_MODE=legacy
# Whether to enforce requiredPermissions at execute entry
TOOLS_AUTH_STRICT_PERMISSIONS=false
# Agent credential JWT signing secret (required)
AGENT_TOOLS_JWT_SECRET=replace_with_strong_tools_jwt_secret
AGENT_TOOLS_JWT_ISSUER=harbin-agents-auth
AGENT_TOOLS_JWT_AUDIENCE=tools-api
AGENT_TOOLS_JWT_TTL_SECONDS=600
# Optional pepper for credential secret hash
AGENT_TOOLS_CREDENTIAL_PEPPER=

GATEWAY_PROXY_TIMEOUT_MS=30000
# Optional: longer timeout for orchestration task debug-run endpoint
GATEWAY_DEBUG_RUN_TIMEOUT_MS=180000

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Database
MONGODB_URI=mongodb://localhost:27017/ai-agent-team

# AI Model API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_claude_key_here
GOOGLE_AI_API_KEY=your_gemini_key_here
MOONSHOT_API_KEY=your_kimi_key_here

# AI Provider V2 Gradual Migration (Vercel AI SDK)
# false: keep all traffic on legacy providers
# true: route matched traffic to AIV2Provider
LLM_PROVIDER_V2_ENABLED=false
# provider allowlist, comma-separated, e.g. openai,anthropic or *
LLM_PROVIDER_V2_PROVIDERS=
# model allowlist, comma-separated, e.g. gpt-4o,claude-3-5-sonnet or *
LLM_PROVIDER_V2_MODELS=

# OpenAI Stability (optional)
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=1

# Agent tool-calling
# Maximum tool-call rounds per task execution (fallback default: 30)
MAX_TOOL_ROUNDS=30
# Enable timing_debug logs in AgentExecutorService (true/false, default: false)
AGENT_DEBUG_TIMING=false

# Optional: Proxy for AI model requests (if direct network is blocked)
AI_PROXY_URL=http://127.0.0.1:7890

# OpenCode SDK
OPENCODE_SERVER_URL=http://localhost:4096
# Whether to enforce agent.config.execution.modelPolicy.bound check during OpenCode session/message calls
OPENCODE_MODEL_BINDING_CHECK_ENABLED=false

# Engineering Intelligence
GITHUB_TOKEN=your_github_token_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Encryption
# 用于加密存储API Key的主密钥
# 请生成一个强密钥，例如: openssl rand -base64 32
# 重要：一旦设置并创建加密数据后，请勿更改此密钥，否则已加密数据将无法解密
ENCRYPTION_KEY=your_encryption_key_here_min_16_chars

# ============================================
# Tool APIs - 工具真实 API 配置 (Composio)
# ============================================

# Exa API Key - 默认网络搜索工具
# 注册地址: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_exa_api_key_here

# Composio API Key - 统一的工具平台
# 注册地址: https://www.composio.dev
# Composio 提供 1000+ 工具的统一接入（包括 Slack、Gmail、Search 等）
# 免费额度: 1000 次/月，无需单独管理各平台 OAuth
COMPOSIO_API_KEY=ak_yWMRCXiXFTgQWDe3xeal

# Web Search 配置 (Serper via Composio)
# Composio 会自动处理 Serper 的认证，无需单独配置 SERPER_API_KEY
# 如需使用自己的 Serper API Key（可选）
SERPER_API_KEY=

# Slack 配置 (via Composio)
# 在 Composio Dashboard 中连接 Slack 账号后，通过 Composio 调用
# 如需使用自己的 Slack Bot Token（可选）
SLACK_BOT_TOKEN=

# Gmail 配置 (via Composio)
# 在 Composio Dashboard 中连接 Gmail 账号后，通过 Composio 调用
# 如需使用自己的 Gmail OAuth（可选）
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# MEMO_AGGREGATION_INTERVAL_MS：周期 flush topic/event 聚合
# MEMO_FULL_AGGREGATION_INTERVAL_MS：周期执行 full aggregation（包含 identity + evaluation）
# MEMO_SCHEDULER_ENABLED=false 可整体关闭这组定时任务
PLANNER_MAX_TASKS=8	# 计划最大任务数
PLANNER_MAX_TITLE_LENGTH=120	# 任务标题最大长度
PLANNER_MAX_DESCRIPTION_LENGTH=1000	# 任务描述最大长度
PLANNER_MIN_DESCRIPTION_LENGTH=20	# 任务描述最小长度（质量检查）
PLANNER_AGENT_MANIFEST_MAX_LENGTH=2000	# Agent Manifest 注入最大长度
PLANNER_REQUIREMENT_DETAIL_MAX_LENGTH=1500	# Requirement 详情注入最大长度
PLANNER_EI_REQUEST_TIMEOUT_MS=5000	# EI 需求查询超时
EXECUTOR_WEIGHT_ROLE=40	# 执行者角色匹配权重
EXECUTOR_WEIGHT_TOOL=30	# 执行者工具覆盖权重
EXECUTOR_WEIGHT_CAPABILITY=20	# 执行者能力标签权重
EXECUTOR_WEIGHT_KEYWORD=10	# 执行者关键词相关性权重
EXECUTOR_MIN_SCORE_THRESHOLD=0	# 执行者最小分数阈值