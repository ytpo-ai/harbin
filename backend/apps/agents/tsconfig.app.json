{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../../dist",
    "rootDir": "../../",
    "declaration": false
  },
  "include": [
    "src/**/*.ts",
    "../../libs/**/*.ts",
    "../../src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "src/**/*.spec.ts",
    "../../src/**/*.spec.ts",
    "../../libs/**/*.spec.ts",
    "**/*.spec.ts"
  ]
}
