{
  "name": "ytpo-ai-backend",
  "version": "1.0.0",
  "description": "ytpo-ai Backend",
  "main": "dist/main.js",
  "scripts": {
    "reload": "bash ./reload.sh",
    "build": "pnpm run build:all",
    "build:all": "pnpm run build:legacy && pnpm run build:gateway && pnpm run build:agents && pnpm run build:ws && pnpm run build:ei",
    "build:legacy": "nest build legacy",
    "build:gateway": "nest build gateway",
    "build:agents": "nest build agents",
    "build:ws": "nest build ws",
    "build:ei": "nest build ei",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:debug": "nest start legacy --debug --watch",
    "start:prod": "node dist/apps/legacy/src/main.js",
    "start:prod:legacy": "node dist/apps/legacy/src/main.js",
    "start:prod:gateway": "node dist/apps/gateway/src/main.js",
    "start:prod:agents": "node dist/apps/agents/src/main.js",
    "start:prod:ws": "node dist/apps/ws/src/main.js",
    "start:prod:ei": "node dist/apps/ei/src/main.js",
    "start:legacy": "nest start legacy --watch",
    "start:gateway": "nest start gateway --watch",
    "start:agents": "nest start agents --watch",
    "start:ws": "nest start ws --watch",
    "start:ei": "nest start ei --watch",
    "dev:all": "npm run start:gateway -- --watch",
    "seed:manual": "ts-node -r tsconfig-paths/register scripts/seed/seed-runner.ts",
    "seed:system-schedules": "npm run seed:manual -- --only=system-schedules",
    "seed:docs-heat": "npm run seed:manual -- --only=docs-heat",
    "seed:meeting-monitor": "npm run seed:manual -- --only=meeting-monitor",
    "maintain": "ts-node -r tsconfig-paths/register scripts/maintenance/maintenance-runner.ts",
    "maintain:cleanup-runtime": "ts-node -r tsconfig-paths/register scripts/maintenance/maintenance-runner.ts --task=cleanup-runtime",
    "maintain:cleanup-redis": "npm run maintain -- --task=cleanup-redis",
    "maintain:cleanup-ended-meetings": "npm run maintain -- --task=cleanup-ended-meetings",
    "maintain:backup": "npm run maintain -- --task=backup",
    "maintain:restore": "npm run maintain -- --task=restore",
    "cleanup:agents-runtime": "ts-node -r tsconfig-paths/register scripts/maintenance/maintenance-runner.ts --task=cleanup-runtime",
    "migrate:skill-content": "ts-node -r tsconfig-paths/register scripts/migrate/migrate-skill-content-to-db.ts",
    "migrate:unset-skill-planning-rules": "ts-node -r tsconfig-paths/register scripts/migrate/unset-skill-planning-rules.ts",
    "migrate:tool-prompts": "ts-node -r tsconfig-paths/register scripts/migrate/backfill-tool-prompts.ts",
    "migrate:cleanup-removed-requirement-tools": "ts-node -r tsconfig-paths/register scripts/migrate/cleanup-removed-requirement-tools.ts",
    "migrate:agent-profile-permissions": "ts-node -r tsconfig-paths/register scripts/migrate/migrate-agent-profile-permissions.ts",
    "migrate:role-tier": "ts-node -r tsconfig-paths/register scripts/migrate/migrate-role-tier.ts",
    "migrate:inner-message-collections": "ts-node -r tsconfig-paths/register scripts/migrate/migrate-inner-message-collections.ts",
    "migrate:schema-collection-governance": "ts-node -r tsconfig-paths/register scripts/migrate/migrate-schema-collection-governance.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.9.1",
    "@composio/core": "^0.5.5",
    "@google-ai/generativelanguage": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-ws": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/websockets": "^10.0.0",
    "ai": "^6.0.116",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron": "^3.2.1",
    "eventemitter2": "^6.4.9",
    "express": "^4.22.1",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.9.3",
    "mongoose": "^8.0.0",
    "openai": "^4.20.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "undici": "^7.22.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "target": "es2020",
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true,
            "experimentalDecorators": true,
            "emitDecoratorMetadata": true,
            "types": [
              "node",
              "jest"
            ]
          }
        }
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@agent/(.*)$": "<rootDir>/apps/agents/src/$1",
      "^@agents/(.*)$": "<rootDir>/apps/agents/src/$1",
      "^@gateway/(.*)$": "<rootDir>/apps/gateway/src/$1",
      "^@ws/(.*)$": "<rootDir>/apps/ws/src/$1",
      "^@ei/(.*)$": "<rootDir>/apps/ei/src/$1",
      "^@legacy/(.*)$": "<rootDir>/src/$1",
      "^@legecy/(.*)$": "<rootDir>/src/$1",
      "^@libs/contracts$": "<rootDir>/libs/contracts/src/index",
      "^@libs/contracts/(.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@libs/auth$": "<rootDir>/libs/auth/src/index",
      "^@libs/auth/(.*)$": "<rootDir>/libs/auth/src/$1",
      "^@libs/common$": "<rootDir>/libs/common/src/index",
      "^@libs/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@libs/infra$": "<rootDir>/libs/infra/src/index",
      "^@libs/infra/(.*)$": "<rootDir>/libs/infra/src/$1",
      "^@libs/models$": "<rootDir>/libs/models/src/index",
      "^@libs/models/(.*)$": "<rootDir>/libs/models/src/$1"
    }
  }
}
