{
  "name": "ai-agent-team-backend",
  "version": "1.0.0",
  "description": "AI Agent Team Platform Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build legacy",
    "build:gateway": "nest build gateway",
    "build:agents": "nest build agents",
    "build:ws": "nest build ws",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start legacy",
    "start:dev": "nest start legacy --watch",
    "start:debug": "nest start legacy --debug --watch",
    "start:prod": "node dist/apps/legacy/main",
    "start:gateway": "nest start gateway",
    "start:gateway:dev": "nest start gateway --watch",
    "start:agents": "nest start agents",
    "start:agents:dev": "nest start agents --watch",
    "start:ws": "nest start ws",
    "start:ws:dev": "nest start ws --watch",
    "dev:all": "npm run start:gateway:dev",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@composio/core": "^0.5.5",
    "@google-ai/generativelanguage": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-ws": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@opencode-ai/sdk": "^1.2.15",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.9.3",
    "mongoose": "^8.0.0",
    "openai": "^4.20.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "undici": "^7.22.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
