{
  "name": "ai-agent-team-backend",
  "version": "1.0.0",
  "description": "AI Agent Team Platform Backend",
  "main": "dist/main.js",
  "scripts": {
    "reload": "(lsof -ti :3001; lsof -ti :3002; lsof -ti :3003; lsof -ti :3100; lsof -ti :3201) 2>/dev/null | sort -u | xargs -r kill; sleep 2; nohup npm run start:dev > /tmp/legacy-app.log 2>&1 & nohup npm run start:agents:dev > /tmp/agents-app.log 2>&1 & nohup npm run start:gateway:dev > /tmp/gateway-app.log 2>&1 & nohup npm run start:ws:dev > /tmp/ws-app.log 2>&1 & nohup npm run start:ei:dev > /tmp/engineering-intelligence-app.log 2>&1 & sleep 8; lsof -nP -i :3001 -i :3002 -i :3003 -i :3100 -i :3201 | grep LISTEN",
    "build": "nest build legacy",
    "build:gateway": "nest build gateway",
    "build:agents": "nest build agents",
    "build:ws": "nest build ws",
    "build:ei": "nest build engineering-intelligence",
    "build:engineering-intelligence": "npm run build:ei",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start legacy",
    "start:dev": "nest start legacy --watch",
    "start:debug": "nest start legacy --debug --watch",
    "start:prod": "node dist/apps/legacy/main",
    "start:gateway": "nest start gateway",
    "start:gateway:dev": "nest start gateway --watch",
    "start:agents": "nest start agents",
    "start:agents:dev": "nest start agents --watch",
    "start:ws": "nest start ws",
    "start:ws:dev": "nest start ws --watch",
    "start:ei": "nest start engineering-intelligence",
    "start:ei:dev": "nest start engineering-intelligence --watch",
    "start:engineering-intelligence": "npm run start:ei",
    "start:engineering-intelligence:dev": "npm run start:ei:dev",
    "dev:all": "npm run start:gateway:dev",
    "seed:manual": "ts-node -r tsconfig-paths/register scripts/manual-seed.ts",
    "migrate:skill-content": "ts-node -r tsconfig-paths/register scripts/migrate-skill-content-to-db.ts",
    "migrate:tool-prompts": "ts-node -r tsconfig-paths/register scripts/backfill-tool-prompts.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.9.1",
    "@composio/core": "^0.5.5",
    "@google-ai/generativelanguage": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-ws": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/websockets": "^10.0.0",
    "@opencode-ai/sdk": "^1.2.15",
    "ai": "^6.0.116",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron": "^3.2.1",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.9.3",
    "mongoose": "^8.0.0",
    "openai": "^4.20.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "undici": "^7.22.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "target": "es2020",
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true,
            "experimentalDecorators": true,
            "emitDecoratorMetadata": true,
            "types": [
              "node",
              "jest"
            ]
          }
        }
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@libs/contracts$": "<rootDir>/libs/contracts/src/index",
      "^@libs/contracts/(.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@libs/auth$": "<rootDir>/libs/auth/src/index",
      "^@libs/auth/(.*)$": "<rootDir>/libs/auth/src/$1",
      "^@libs/common$": "<rootDir>/libs/common/src/index",
      "^@libs/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@libs/infra$": "<rootDir>/libs/infra/src/index",
      "^@libs/infra/(.*)$": "<rootDir>/libs/infra/src/$1",
      "^@libs/models$": "<rootDir>/libs/models/src/index",
      "^@libs/models/(.*)$": "<rootDir>/libs/models/src/$1"
    }
  }
}
