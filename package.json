{
  "name": "ai-agent-team-platform",
  "version": "1.0.0",
  "description": "通用AI助手平台 - 支持多模型接入的Agent团队协作系统",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:engineering-intelligence": "cd backend && npm run start:ei:dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:engineering-intelligence": "cd backend && npm run build:ei",
    "start": "cd backend && npm start",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "test": "cd backend && npm test"
  },
  "keywords": ["ai", "agent", "team", "llm", "collaboration"],
  "author": "AI Team Platform",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
